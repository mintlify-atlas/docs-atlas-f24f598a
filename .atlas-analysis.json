  "keyFeatures": [
    "Header-only single-include library (no linking required)",
    "Hardware performance counters: CPU cycles, instructions, branches, branch misses",
    "Automatic statistical analysis with 95% confidence interval-based iteration control",
    "Cache-aware benchmarking with L1 cache eviction between runs",
    "Multiple output formats: console, Markdown, SVG bar charts, and JSON",
    "Parameterized benchmarks with run_with()",
    "Per-iteration setup support via run_with_setup()",
    "Cross-platform: Windows, Linux, macOS (including Apple Silicon)",
    "Compiler support: GCC, Clang, MSVC, Apple Clang"
  ],
  "publicApiSurface": [
